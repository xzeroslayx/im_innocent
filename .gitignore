.obsidian/workspace*
.obsidian/cache/
.trash/
.DS_Store
Thumbs.db
# Ignore ALL hidden files and folders
.*

# But keep .gitignore itself
!.gitignore

# Optional: keep README if you add one later
!.README.md

# Obsidian internal cache
.obsidian/workspace.json
.obsidian/cache/
.obsidian/workspace-mobile.json
# Ignore Obsidian/system folders anywhere (nested vaults too)
**/.obsidian/
**/.makemd/
**/.space/
**/.trash/
**/.DS_Store
**/Thumbs.db
